{
  "expo": {
    "name": "AI Eco-dictionary",
    "slug": "AIEcoDictionary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ai_eco-lexicon_icon.png",
    "scheme": "aiecodictionary",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/ai_eco-lexicon_icon.png",
        "backgroundImage": "./assets/images/ai_eco-lexicon_icon.png",
        "monochromeImage": "./assets/images/ai_eco-lexicon_icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.khannibal.aiecodictionary"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ai_eco-lexicon_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ai_eco-lexicon_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f41cb96b-7116-41d9-b521-ac920c08d9e9"
      }
    }
  }
}
